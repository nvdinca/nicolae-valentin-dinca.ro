# Copiază în `.env.local` pentru development (nu comita `.env.local`).

# Plausible Analytics — încărcat doar dacă utilizatorul acceptă cookie‑urile „statistici”.
# Domeniul site‑ului, fără https:// (ex.: nicolae-valentin-dinca.ro).
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=

# Opțional: Sentry (monitorizare erori) — necesită integrare manuală @sentry/nextjs dacă activezi.
# SENTRY_AUTH_TOKEN=
# NEXT_PUBLIC_SENTRY_DSN=
